# FBN Fleet Management System — environment variables
# Frontend build vars (Vite). In production these are set in the Cloudflare
# Workers Builds project (Settings → Build → Variables), baked in at build time
# because they are VITE_-prefixed. Copy this to .env.local for local dev.

# Supabase (project: kyosepbdxjwugunylvyo)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key

# Google Gemini — document scanning, FAQ chatbot, AI dispatch (exposed as process.env.API_KEY via vite define)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Google Maps JavaScript API — address autocomplete (loaded in index.html)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# --- Supabase Edge Function secrets (set with `supabase secrets set`, NOT here) ---
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY  (auto-provided to functions)
# GOOGLE_SA_KEY        — service-account JSON for Drive/Sheets imports (fbn-fleet-reader@...)
# GEMINI_API_KEY       — server-side Gemini (public FAQ bot)
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY     — web push
# (Gmail / Twilio / WhatsApp creds for send-email / send-whatsapp)
